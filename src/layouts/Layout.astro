---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'Claude 101',
  description = '以 AI 的第一人称视角，交互式理解 Claude Code 的工作原理',
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W604S49M4X" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W604S49M4X');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=ZCOOL+KuaiLe&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      /* Critical: hide article before React hydrates to prevent flash */
      .chapter-article { display: none !important; }
      body.scroll-unlocked .chapter-article { display: block !important; }
    </style>
    <script is:inline>
      // Sync lang attribute before first paint to avoid flash
      (function() {
        var lang = localStorage.getItem('claude101-lang') || 'zh';
        document.documentElement.lang = lang === 'en' ? 'en' : 'zh-CN';
        document.documentElement.dataset.lang = lang;
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
